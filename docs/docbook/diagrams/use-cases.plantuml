@startuml
title SaxonForms implementation use-cases
left to right direction
skinparam packageStyle rectangle

actor "Form Author" as AUTHOR
actor "Application Developer" as DEV
actor "End User" as USER
actor "QA Engineer" as QA

rectangle "SaxonForms Runtime" {
  usecase "Render XForms Controls\n(input/output/select/repeat/switch)" as UC_RENDER
  usecase "Evaluate XPath/XForms Functions\n(xforms:impose, xforms:instance,\nxforms:id, xforms:index)" as UC_XPATH
  usecase "Run Actions\n(insert/delete/toggle/setvalue/\nsetindex/dispatch/load/script)" as UC_ACTIONS
  usecase "Submit Instance Data\n(HTTPsubmit, ixsl:promise)" as UC_SUBMIT
  usecase "Dispatch Lifecycle Events\n(model-construct/ready/\nrecalculate/revalidate/refresh)" as UC_EVENTS
  usecase "Validate Conformance via\nW3C Playwright Suite\n(ch02-ch11, appendix)" as UC_W3C
  usecase "Upload File to Instance\n(readFileAsXML)" as UC_UPLOAD
}

AUTHOR --> UC_RENDER
AUTHOR --> UC_XPATH
DEV --> UC_ACTIONS
DEV --> UC_SUBMIT
DEV --> UC_UPLOAD
USER --> UC_EVENTS
USER --> UC_RENDER
QA --> UC_W3C
QA --> UC_EVENTS
@enduml
