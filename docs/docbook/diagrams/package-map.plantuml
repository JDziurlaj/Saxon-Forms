@startuml
title SaxonForms package map (XSLT-centered)
skinparam packageStyle rectangle

package "src/" {
  [saxon-xforms.xsl\n~8100 lines\nMain transform: controls, actions,\nmodel lifecycle, submission] as SAXON_XFORMS
  [xforms-function-library.xsl\n~300 lines\nimpose(), instance(), index(),\nid(), min(), max(), random()] as FUNCTION_LIBRARY
  [xforms-xpath-functions.xsl\n~420 lines\nproperty(), boolean-from-string(),\navg(), days-from-date(), digest(),\nhmac(), event(), now()] as XPATH_FUNCTIONS
  [xsd-helpers.xsl\n~148 lines\ncanonical-type(), is-type-valid()] as XSD_HELPERS
  package "packages/" {
    [logger.xsl\nsfp:logInfo, sfp:logDebug\nOptional tracing] as LOGGER
  }
}

package "scripts/" {
  [run-playwright-with-port.mjs\nTest harness launcher] as RUN_PLAYWRIGHT
  [xd-doc-extract.xsl\nAPI doc extraction] as XD_DOC
}

package "tests/w3c/" {
  [ch02-03.spec.ts] as CH02_03
  [ch04.spec.ts\nProcessing model] as CH04
  [ch05.spec.ts\nData types] as CH05
  [ch06.spec.ts\nMIPs] as CH06
  [ch07.spec.ts\nXPath] as CH07
  [ch08.spec.ts\nCore controls] as CH08
  [ch09.spec.ts\nContainer controls] as CH09
  [ch10.spec.ts\nActions] as CH10
  [ch11.spec.ts\nSubmission] as CH11
  [appendix.spec.ts\nInsert/delete patterns] as APPX
}

SAXON_XFORMS --> FUNCTION_LIBRARY : xsl:use-package
SAXON_XFORMS --> XPATH_FUNCTIONS : xsl:use-package
SAXON_XFORMS --> XSD_HELPERS : xsl:use-package
SAXON_XFORMS --> LOGGER : xsl:use-package
RUN_PLAYWRIGHT --> CH04
RUN_PLAYWRIGHT --> CH07
RUN_PLAYWRIGHT --> CH10
RUN_PLAYWRIGHT --> CH11
XD_DOC --> SAXON_XFORMS : extracts xd:doc annotations
@enduml
