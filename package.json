{
  "name": "saxon-forms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "verify:setup": "npm run verify:setup:docker",
    "verify:setup:local": "node scripts/verify-setup-local.mjs",
    "verify:setup:docker": "node scripts/verify-setup-docker.mjs",
    "build:sef": "npx xslt3 -t -xsl:src/saxon-xforms.xsl -export:sef/saxon-xforms.sef.json -nogo \"-ns:##html5\" && node -e \"require('fs').cpSync('sef/saxon-xforms.sef.json','test-app/sef/saxon-xforms.sef.json')\"",
    "predev": "node scripts/fetch-w3c-suite.mjs && node -e \"const fs=require('fs');const t='test-app/w3c-suite';if(!fs.existsSync(t)){fs.symlinkSync(require('path').resolve('public-test/w3c-suite'),t,'junction')}\"",
    "fetch:w3c": "node scripts/fetch-w3c-suite.mjs",
    "fetch:nist": "node scripts/fetch-nist-xsdtests.mjs",
    "test:baseline": "node scripts/create-playwright-baseline.mjs --all",
    "test:gate": "node .agents/skills/regression-gate/scripts/run_regression_gate.mjs",
    "examples": "node examples/server.mjs",
    "examples:compile": "node examples/compile-examples.mjs",
    "dev": "npx http-server test-app -p 5174 -c-1",
    "test:e2e": "node scripts/run-playwright-with-port.mjs --config=playwright.config.ts",
    "test:e2e:chrome": "node scripts/run-playwright-with-port.mjs --browser=chrome --config=playwright.config.ts",
    "test:e2e:firefox": "node scripts/run-playwright-with-port.mjs --browser=firefox --config=playwright.config.ts",
    "test:e2e:both": "node scripts/run-playwright-with-port.mjs --browser=both --config=playwright.config.ts",
    "test:e2e:full": "npm run predev && npm run build:sef && npm run test:e2e",
    "test:e2e:ui": "node scripts/run-playwright-with-port.mjs --config=playwright.config.ts --ui",
    "test:e2e:diagnostics": "node scripts/run-playwright-with-port.mjs --include-diagnostics --config=playwright.config.ts tests/diagnostics",
    "test:xsd-helpers": "npx xslt3 -xsl:tests/xsd-helpers.spec.xsl -s:tests/xsd-helpers-cases.xml",
    "test:nist-facets": "node scripts/run-nist-facet-harness.mjs --engine saxonforms",
    "test:nist-facets:inventory": "node scripts/run-nist-facet-inventory.mjs --engine saxonforms --jobs 1",
    "test:nist-facets:list": "node scripts/run-nist-facet-harness.mjs --list-only",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:docbook:validate": "node scripts/validate-docbook-sources.mjs",
    "docs:docbook:build": "node scripts/run-docbook-build.mjs",
    "docs:docbook:checkpoints": "node scripts/run-docbook-checkpoints.mjs --list"
  },
  "devDependencies": {
    "@noble/hashes": "^2.0.1",
    "@playwright/test": "^1.50.0",
    "@shoelace-style/shoelace": "^2.20.1",
    "http-server": "^14.1.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "tsx": "^4.21.0",
    "vite": "^6.4.1",
    "xslt3": "^2.7.0"
  }
}
